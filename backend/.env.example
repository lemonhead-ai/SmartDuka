SMARTDUKA_APP_NAME=Smart Duka API
SMARTDUKA_APP_VERSION=0.1.0
SMARTDUKA_ENVIRONMENT=development
SMARTDUKA_DEBUG=false
SMARTDUKA_LOG_LEVEL=INFO
SMARTDUKA_API_V1_PREFIX=/api/v1
SMARTDUKA_DATABASE_URL=sqlite+aiosqlite:///./smartduka.db
SMARTDUKA_LLM_PROVIDER=featherless
SMARTDUKA_FEATHERLESS_API_KEY=
SMARTDUKA_FEATHERLESS_MODEL=Qwen/Qwen3-32B
SMARTDUKA_FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
SMARTDUKA_FEATHERLESS_ENABLE_THINKING=false
SMARTDUKA_ALLOWED_ORIGINS=["http://localhost:3000"]
